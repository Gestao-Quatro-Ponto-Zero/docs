{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "G4 OS",
  "colors": {
    "primary": "#B9915B",
    "light": "#184560",
    "dark": "#001F35"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Download",
          "icon": "download",
          "color": {
            "light": "#184560",
            "dark": "#184560"
          },
          "href": "https://g4oscloud.com/download-public"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contato@g4business.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "instagram": "https://instagram.com/g4.business",
      "website": "https://g4oscloud.com/download-public"
    }
  },
  "description": "Entenda como usar o G4 OS",
  "favicon": "/images/icon.png",
  "logo": "/images/g4os_logo_white.png"
}
